{
  "users": [
    {
      "name": "${RABBITMQ_DEFAULT_USER}",
      "password_hash": "${RABBITMQ_PASSWORD_HASH}",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["administrator"]
    },
    {
      "name": "${RABBITMQ_API_USER}",
      "password_hash": "${RABBITMQ_API_PASSWORD_HASH}",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["monitoring"]
    }
  ],
  "vhosts": [{ "name": "/" }],
  "permissions": [
    {
      "user": "${RABBITMQ_DEFAULT_USER}",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "${RABBITMQ_API_USER}",
      "vhost": "/",
      "configure": "",
      "write": ".*",
      "read": ".*"
    }
  ],
  "queues": [
    {
      "name": "worker-tasks",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "",
        "x-dead-letter-routing-key": "worker-tasks.failed"
      }
    },
    {
      "name": "worker-tasks.failed",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "worker-events",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ]
}
