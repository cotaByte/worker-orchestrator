{
  "vhosts": [{ "name": "/" }],
  "queues": [
    {
      "name": "worker-tasks",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "",
        "x-dead-letter-routing-key": "worker-tasks.failed"
      }
    },
    {
      "name": "worker-tasks.failed",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "worker-events",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ]
}
