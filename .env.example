# ─── QUEUE ────────────────────────────────────────────
# Credentials used by the RabbitMQ container on first boot
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=changeme

# Connection URL used by the orchestrator service
RABBITMQ_URL=amqp://admin:changeme@rabbitmq:5672

# Queue configuration consumed by queueConsumer.service.ts
RABBITMQ_QUEUE=worker-tasks
RABBITMQ_PREFETCH=5
